{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "./scripts/hooks/session-start.sh",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "./scripts/hooks/session-end.sh",
        "cwd": ".",
        "timeoutSec": 15
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "./scripts/hooks/subagent-stop.sh",
        "cwd": ".",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "./scripts/hooks/log-prompt.sh",
        "cwd": ".",
        "timeoutSec": 5
      }
    ]
  }
}
